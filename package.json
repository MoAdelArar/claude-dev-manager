{
  "name": "claude-dev-manager",
  "version": "2.2.0",
  "description": "AI-powered development manager — 5 agents, 17 composable skills, 6 pipeline templates, powered by Claude Code",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "dist/types.d.ts",
  "bin": {
    "cdm": "dist/cli/index.js",
    "cdm-mcp-server": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "templates",
    "commands",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs || true",
    "build": "tsc",
    "build:bun": "bun build src/cli/index.tsx --outdir dist --target node && bun build src/mcp-server.ts --outdir dist --target node",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.tsx",
    "test": "bun test --coverage",
    "test:unit": "bun test --test-name-pattern unit",
    "test:integration": "bun test --test-name-pattern integration",
    "test:e2e": "bun test --test-name-pattern e2e --timeout 120000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "mcp": "node dist/mcp-server.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --project tsconfig.test.json --noEmit",
    "pretest": "bun run typecheck",
    "prepublishOnly": "bun run lint && bun test && bun run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "development",
    "project-management",
    "multi-agent",
    "software-engineering",
    "pipeline",
    "skills",
    "devops",
    "aws",
    "gcp",
    "azure",
    "mcp",
    "rtk"
  ],
  "optionalBinaryDependencies": {
    "rtk": {
      "version": ">=0.20.0",
      "description": "CLI proxy that reduces LLM token consumption by 60-90%",
      "install": "brew install rtk && rtk init --global",
      "url": "https://github.com/rtk-ai/rtk"
    }
  },
  "author": "MoAdelArar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MoAdelArar/claude-dev-manager.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "bun": "^1.3.10",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "pastel": "^4.0.0",
    "react": "^19.0.0",
    "uuid": "^10.0.0",
    "vitest": "^4.1.0",
    "winston": "^3.17.0",
    "yaml": "^2.6.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.15.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
